# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*
firebase-debug.*.log*

# Firebase cache
.firebase/

# Firebase config
# NOTE: js/firebase-config.js 裡的 apiKey 是 Firebase Web 識別碼，
# 官方說明可以放進 source code（安全性由 Firestore 規則控制）
# 參考：https://firebase.google.com/docs/projects/api-keys
# 因此 firebase-config.js 不需要加入 .gitignore

# .firebaserc 含有 projectId，可選擇是否公開（低風險）
# 若不希望公開專案名稱，可取消下方註解：
# .firebaserc

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.local
.env.*.local

# dataconnect generated files
.dataconnect

# ============================================================
# SKYSER 專案專屬
# ============================================================

# 若未來使用 Service Account 金鑰（後端 / Cloud Functions 用）
# 這類檔案絕對不能上傳！
service-account*.json
*-service-account.json
secrets/

# macOS 系統檔
.DS_Store
.AppleDouble
.LSOverride

# Windows 系統檔
Thumbs.db
ehthumbs.db
desktop.ini

# VS Code 本地設定（個人偏好，不強制同步）
.vscode/settings.json
.vscode/launch.json

# 本地測試用暫存
*.local.js
